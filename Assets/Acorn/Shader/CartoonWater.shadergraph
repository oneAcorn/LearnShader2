{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "2ef3ea920b5449a8a11d5cdb3a841e90",
    "m_Title": "深度信息",
    "m_Content": "SceneDepth节点可访问场景中特定像素的深度信息.其获取摄像机与当前正在着色的像素之间的距离.\n\n深度缓冲区是一个中间缓冲区,存储场景中对象与摄像机之间的距离信息, 也被称为z-buffer.\n\n模式:\nLinear 0-1: 输出归一化的深度值,0表示离摄像机最近,1表示离摄像机最远的对象.\nRaw: 输出未经过修改或转换的原始深度值, 表示对象到摄像机的绝对距离.\nEye: 提供相对于摄像机视觉空间(Eye Space)的深度值, 它考虑到了摄像机的位置,朝向和视野. 在需要根据视觉空间的视觉进行计算时,此模式很好用.",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": -2237.0,
        "y": 47.0,
        "width": 217.0,
        "height": 284.0
    },
    "m_Group": {
        "m_Id": "3db8f506500e4100859476a1982f2b74"
    }
}

